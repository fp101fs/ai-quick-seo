# OpenRouter — powers content refresh, daily task prioritization,
# internal link suggestions, and the AI coach.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the AI model (defaults to openrouter/free)
# OPENROUTER_MODEL=openrouter/free

# Google OAuth — powers Sign In + Search Console integration.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Leave blank to use the app in demo mode only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Neon (Vercel Postgres) — auto-added by Vercel when you connect a Neon DB.
# Run POST /api/migrate with x-migrate-secret header to initialize tables.
POSTGRES_URL=
MIGRATE_SECRET=

# Stripe — payments and subscription management
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Session security — HMAC key for signing the user ID cookie. Use a strong random string in prod.
SESSION_SECRET=

# Google Analytics 4 measurement ID (optional, e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Public URL of your deployment (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://ai-quick-seo.vercel.app
