# OpenRouter — powers content refresh, daily task prioritization,
# internal link suggestions, and the AI coach.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the AI model (defaults to openrouter/free)
# OPENROUTER_MODEL=openrouter/free

# Google OAuth — powers the Search Console integration.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Leave blank to use the app in demo mode only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
